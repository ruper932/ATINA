@startuml
left to right direction
skinparam packageStyle rectangle

actor "Administrador/Docente" as Admin
actor "Estudiante" as Estudiante
actor "Sensor IoT" as Sensor
actor "Modelo ML" as ML
actor "Servidor MCP" as MCP

rectangle "Sistema de Monitoreo e Inteligencia Hídrica" {
  usecase "Monitorear variables meteorológicas" as UC1 <<monitoring>> 
  usecase "Registrar caudal de agua captada" as UC2 <<acquisition>> 
  usecase "Consultar predicción de agua diaria" as UC3 <<prediction>> 
  usecase "Calcular riego recomendado" as UC4 <<optimization>> 
  usecase "Simular escenarios futuros" as UC5 <<scenario>> 
  usecase "Visualizar reportes y alertas" as UC6 <<visualization>> 
  usecase "Administrar sensores y modelos" as UC7 <<management>> 
  usecase "Consultar historial de datos" as UC8 <<retrieval>> 
}

Sensor --> UC1
Sensor --> UC2
Admin --> UC6
Admin --> UC7
Admin --> UC8
Estudiante --> UC6
Estudiante --> UC3
ML --> UC3
ML --> UC4
ML --> UC5
MCP --> UC1
MCP --> UC2
MCP --> UC3
MCP --> UC4
MCP --> UC5

' Relaciones de include/extend
UC3 ..> UC1 : <<include>>  ' Predicción incluye monitoreo
UC4 ..> UC2 : <<include>>  ' Cálculo de riego incluye registro
UC5 ..> UC1 : <<include>>  ' Simulación incluye monitoreo
UC6 ..> UC3 : <<include>>  ' Visualización incluye predicción
UC6 ..> UC4 : <<include>>  ' Visualización incluye riego
UC6 ..> UC5 : <<include>>  ' Visualización incluye escenarios

@enduml