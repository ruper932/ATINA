@startuml clases
!theme plain
title Sistema Inteligente de Monitoreo y Predicción de Recolección de Agua - Clases
skinparam classAttributeIconSize 0
skinparam wrapWidth 200

package "Perfil" as per {
  class Usuario {
    +id: int
    +nombre: string
    +email: string
    +rol: enum
    +password_hash: string
    +verificar_2fa()
  }
  class Docente as PerfilDocente {
    +area_investigacion: string
    +proyectos: string[]
  }
}

package "IoT & Edge" as iot {
  class SensorMeteorologico {
    +id: int
    +tipo: enum
    +temperatura: float
    +presion: float
    +humedad: float
    +viento: float
    +leer_datos()
    +calibrar()
  }
  class Caudalimetro {
    +id: int
    +tipo: string
    +caudal: float
    +estado: enum
    +registrar_caudal()
    +reset_diario()
  }
  class Atrapanieblas {
    +id: int
    +ubicacion: string
    +coord_gps: (float,float)
    +area_malla: float
    +estado: enum
    +captar_agua()
    +limpiar_malla()
  }
}

package "Interoperabilidad" as interop {
  class ServidorMCP {
    +puerto: int
    +max_conexiones: int
    +recibir_datos()
    +validar_mensaje()
    +distribuir_datos()
    +log_eventos()
  }
}

package "Inteligencia" as ml {
  class ModeloPrediccionAgua {
    +version: string
    +ventana_temporal: int
    +predecir_volumen()
    +evaluar_precision()
    +entrenar()
  }
  class ModeloRiegoEdge {
    +limite_humedad: float
    +calcular_riego()
    +optimizar_dosis()
  }
  class ModeloSimulacionEscenarios {
    +escenarios: dict
    +simular()
    +exportar_csv()
  }
}

package "Aplicación" as app {
  class DashboardWeb {
    +titulo: string
    +tema: string
    +mostrar_datos()
    +mostrar_alertas()
    +generar_reportes()
    +exportar_csv()
  }
  class Reporte {
    +id: int
    +fecha_gen: datetime
    +formato: enum
    +generar_pdf()
    +exportar_csv()
  }
}

package "Dominio" as dom {
  class LecturaSensor {
    +id: int
    +sensor_id: int
    +fecha_hora: datetime
    +valor: float
    +unidad: string
    +calidad: enum
  }
  class Prediccion {
    +id: int
    +modelo_id: int
    +fecha_hora: datetime
    +volumen_estimado: float
    +intervalo_conf: (float,float)
  }
  class Riego {
    +id: int
    +fecha_hora: datetime
    +cantidad_recomendada: float
    +ejecutado: bool
  }
  class Alerta {
    +id: int
    +tipo: enum
    +severidad: enum
    +mensaje: string
    +resuelta: bool
  }
}

' Relaciones
Usuario --> DashboardWeb : configura
SensorMeteorologico --> ServidorMCP : envía datos
Caudalimetro --> ServidorMCP : envía datos
Atrapanieblas --> Caudalimetro : produce flujo
ServidorMCP --> LecturaSensor : almacena
ServidorMCP --> ModeloPrediccionAgua : alimenta
ServidorMCP --> ModeloRiegoEdge : alimenta
ServidorMCP --> ModeloSimulacionEscenarios : alimenta
ModeloPrediccionAgua --> Prediccion : genera
ModeloRiegoEdge --> Riego : genera
DashboardWeb --> Reporte : crea
LecturaSensor --> Prediccion : base de
Prediccion --> Alerta : dispara
Riego --> LecturaSensor : actualiza
Reporte --> Prediccion : incluye

@enduml